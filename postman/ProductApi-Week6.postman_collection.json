    {
      "name": "01 - Shared and health",
      "item": [
        {
          "name": "Health returns 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Health response has the expected shape', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('Healthy');",
                  "    pm.expect(json.message).to.eql('Product API is running.');",
                  "    pm.expect(json).to.have.property('timestampUtc');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "Info returns 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Info response has the expected shape', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.projectName).to.eql('ProductApi');",
                  "    pm.expect(json.version).to.eql('1.0.0');",
                  "    pm.expect(json).to.have.property('framework');",
                  "    pm.expect(json).to.have.property('environment');",
                  "    pm.expect(json).to.have.property('description');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/info"
          }
        }
      ]
