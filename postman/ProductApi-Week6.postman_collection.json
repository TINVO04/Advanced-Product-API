{
  "info": {
    "_postman_id": "a74944a7-03e4-4a19-99a8-c3afe3c2fe50",
    "name": "ProductApi Advanced - Week 6 Regression",
    "description": "Bộ regression test tự chạy cho ProductApi Advanced tuần 6: response wrapper, validation, Category/Product CRUD, search/filter/sort/pagination, soft delete và restore. Collection tự tạo dữ liệu riêng theo timestamp và dọn dữ liệu sau khi chạy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "    const runId = Date.now().toString();",
          "    pm.collectionVariables.set('runId', runId);",
          "    pm.collectionVariables.set('primaryCategoryName', `Regression Category ${runId}`);",
          "    pm.collectionVariables.set('secondaryCategoryName', `Regression Secondary ${runId}`);",
          "    pm.collectionVariables.set('productName', `Regression Product ${runId}`);",
          "    pm.collectionVariables.set('updatedProductName', `Regression Product Updated ${runId}`);",
          "    pm.collectionVariables.set('duplicateCategoryName', `Duplicate Test Category ${runId}`);",
          "    pm.collectionVariables.set('duplicateProductName', `Duplicate Restore Product ${runId}`);",
          "}"
        ]
      }
    }
  ],
